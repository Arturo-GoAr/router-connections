# Copia este archivo a `.env` y ajusta lo que quieras. Todo es opcional:
# la aplicación arranca con estos mismos valores por defecto.

# --- Servidor ---
RC_HOST=127.0.0.1
RC_PORT=8000

# --- Escaneo ---
# Cada cuánto se barre la red automáticamente (segundos).
RC_SCAN_INTERVAL_SECONDS=300
# Barrer al arrancar el servidor.
RC_SCAN_ON_STARTUP=true
# Incluir escaneo de puertos en cada barrido programado. Es bastante más lento,
# por eso está desactivado: se puede lanzar a mano desde la interfaz.
RC_PORT_SCAN_ON_SWEEP=false
# Minutos sin ver un dispositivo antes de darlo por desconectado.
RC_OFFLINE_GRACE_MINUTES=10

# --- Privacidad ---
# Consultar la IP pública a un servicio externo (api.ipify.org). Ponlo en false
# si prefieres que la app no haga ninguna petición fuera de tu red.
RC_ENABLE_PUBLIC_IP_LOOKUP=true

# --- Funciones ---
RC_ENABLE_UPNP=true
RC_ENABLE_WINDOWS_FIREWALL=true
